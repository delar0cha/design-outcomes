---
/**
 * FieldNoteCard.astro — the notebook visual for a Field Notes entry, with
 * a flip-to-page interaction. The card stays as it was; clicking anywhere
 * on it slides a dot-grid "page" up over the cover, displaying a pull
 * quote, a "why it matters" bullet list, a CTA, and a small tactic
 * illustration in the corner.
 *
 * Layering:
 *   .do-fn-card                  position:relative, overflow:visible
 *     .do-fn-card-spine-indent×2 absolute, extends past spine
 *     .do-fn-card-cover          flex child, top 40%
 *     .do-fn-card-band           flex child, extends past edges
 *     .do-fn-card-footer         flex child, bottom region
 *     .do-fn-card-page-clip      absolute inset:0, overflow:hidden — exists
 *                                only to clip .do-fn-card-page when it's
 *                                translated below the card; the card itself
 *                                stays overflow:visible so the band wraps
 *                                and staples poke past the spine.
 *       .do-fn-card-page         absolute inset:0, transform:translateY(100%)
 *                                in default state. The "is-flipped" class on
 *                                the card animates this to translateY(0).
 *
 * Interaction is wired by a single hoisted <script> at the bottom of this
 * file. Astro deduplicates the script across multiple card instances, so
 * it runs once per page and operates over every .do-fn-card.
 */

interface Props {
  slug:               string;
  source:             string;
  source_id:          string;
  source_url:         string;
  piece_title:        string;
  piece_author?:      string;
  piece_published_at?: Date;
  tactic_tags:        readonly string[];
  rubric_rationale:   string;
  /** Pull quote shown on the dot-grid page. May contain ==phrase==
   *  highlight markers that get rendered with a scratch underline. */
  pull_quote?:        string;
  /** Optional fallback when pull_quote isn't set (legacy entries). */
  pull_quote_candidate?: string | null;
  /** 3-5 "why it matters" bullets. Primary editorial content on the page. */
  bullets?:           readonly string[];
  display_type?:      'company' | 'individual';
}

const {
  slug, source, source_id, source_url,
  piece_title, piece_author, piece_published_at,
  tactic_tags, rubric_rationale,
  pull_quote, pull_quote_candidate, bullets,
  display_type = 'company',
} = Astro.props;

// Map a tactic tag to the CSS variable suffix used in :root tokens.
const TACTIC_VAR_KEY: Record<string, string> = {
  research_and_validation:      'research',
  systems_and_primitives:       'systems',
  prototyping_and_exploration:  'prototyping',
  critique_and_decision_making: 'critique',
  craft_and_detail:             'craft',
  cross_functional_and_process: 'cross',
  storytelling_and_narrative:   'storytelling',
  hiring_and_team:              'hiring',
};
const primaryTactic = tactic_tags[0] ?? 'craft_and_detail';
const cssKey        = TACTIC_VAR_KEY[primaryTactic] ?? 'craft';
const coverColor    = `var(--tactic-${cssKey}-cover)`;
const quietColor    = `var(--tactic-${cssKey}-quiet)`;
const wearColor     = `var(--tactic-${cssKey}-wear)`;

// ── Procedural wear (deterministic from slug) ──────────────────────────────
//
// Cards in a working notebook accumulate small scratches, scuffs, and specks.
// We generate these at build time as inline SVG inside the cover. The slug
// seeds a Mulberry32 PRNG so each card has unique-but-stable wear: same slug
// produces the same marks across reloads, different slugs produce different
// marks. Critically, we do NOT use Math.random — that would re-roll on every
// build/reload and the cards would visually flicker.
//
// SVG viewBox is 100×60 (5:3 ratio matching the cover region: cover is 40% of
// a 2:3 card, so width:height = 1 : 0.6 = 5:3). preserveAspectRatio="none"
// is safe at this ratio — the cover always renders 5:3, so no distortion.

function seedFromString(str: string): number {
  let h = 2166136261;
  for (let i = 0; i < str.length; i++) {
    h ^= str.charCodeAt(i);
    h = Math.imul(h, 16777619);
  }
  return h >>> 0;
}
function mulberry32(seed: number): () => number {
  let a = seed >>> 0;
  return function () {
    a = (a + 0x6D2B79F5) | 0;
    let t = Math.imul(a ^ (a >>> 15), 1 | a);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}

// Reject the center 60% × 50% wordmark zone where the type sits. Marks bias
// toward the corners and edges naturally because the center is rejected.
function pickPos(rand: () => number): { x: number; y: number } {
  for (let i = 0; i < 8; i++) {
    const x = rand() * 100;
    const y = rand() * 60;
    const inWordmarkZone = x >= 20 && x <= 80 && y >= 15 && y <= 45;
    if (!inWordmarkZone) return { x, y };
  }
  // Fallback: a corner if rejection sampling can't land.
  return {
    x: rand() < 0.5 ? rand() * 18 : 82 + rand() * 18,
    y: rand() < 0.5 ? rand() * 12 : 48 + rand() * 12,
  };
}

function generateWearSvg(slug: string): string {
  const rand = mulberry32(seedFromString(slug));
  const parts: string[] = [];

  // 2-3 longer scratches — slight curve via a quadratic Bezier control point.
  const scratchCount = 2 + Math.floor(rand() * 2);
  for (let i = 0; i < scratchCount; i++) {
    const { x, y } = pickPos(rand);
    const len   = 10 + rand() * 15;
    const angle = rand() * Math.PI * 2;
    const dx    = Math.cos(angle) * len;
    const dy    = Math.sin(angle) * len;
    const mx    = x + dx / 2 + (rand() - 0.5) * 4;
    const my    = y + dy / 2 + (rand() - 0.5) * 4;
    parts.push(
      `<path d="M${x.toFixed(1)} ${y.toFixed(1)} Q${mx.toFixed(1)} ${my.toFixed(1)} ${(x + dx).toFixed(1)} ${(y + dy).toFixed(1)}" stroke="currentColor" stroke-width="0.5" fill="none" stroke-linecap="round"/>`,
    );
  }

  // 5-7 short scuffs — straight angled marks.
  const scuffCount = 5 + Math.floor(rand() * 3);
  for (let i = 0; i < scuffCount; i++) {
    const { x, y } = pickPos(rand);
    const len   = 3 + rand() * 5;
    const angle = rand() * Math.PI * 2;
    const dx    = Math.cos(angle) * len;
    const dy    = Math.sin(angle) * len;
    parts.push(
      `<path d="M${x.toFixed(1)} ${y.toFixed(1)} L${(x + dx).toFixed(1)} ${(y + dy).toFixed(1)}" stroke="currentColor" stroke-width="0.4" fill="none" stroke-linecap="round"/>`,
    );
  }

  // 4-6 tiny specks — small filled circles.
  const speckCount = 4 + Math.floor(rand() * 3);
  for (let i = 0; i < speckCount; i++) {
    const { x, y } = pickPos(rand);
    const r        = 0.3 + rand() * 0.6;
    parts.push(
      `<circle cx="${x.toFixed(1)}" cy="${y.toFixed(1)}" r="${r.toFixed(2)}" fill="currentColor"/>`,
    );
  }

  return `<svg viewBox="0 0 100 60" preserveAspectRatio="none">${parts.join('')}</svg>`;
}

const wearSvg = generateWearSvg(slug);

// Look up an inline SVG logo in src/assets/source-logos/{source_id}.svg.
const logoSvgs = import.meta.glob<string>('/src/assets/source-logos/*.svg', {
  query: '?raw',
  import: 'default',
  eager: true,
});
const logoSvg = logoSvgs[`/src/assets/source-logos/${source_id}.svg`] ?? null;

// Look up a tactic illustration override in src/assets/tactic-illustrations/{tactic}.svg.
// If present, use it instead of the inline placeholder; Leonardo will drop
// hand-drawn assets there over time.
const tacticIllustrationSvgs = import.meta.glob<string>(
  '/src/assets/tactic-illustrations/*.svg',
  { query: '?raw', import: 'default', eager: true },
);
const tacticOverride = tacticIllustrationSvgs[`/src/assets/tactic-illustrations/${primaryTactic}.svg`] ?? null;

const wordmarkText = source.toUpperCase();

const formatDate = (d?: Date) => {
  if (!d) return '';
  const months = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
  return `${months[d.getMonth()]} ${d.getDate()}, ${d.getFullYear()}`;
};
const dateLabel = formatDate(piece_published_at);

let footerText = '';
if (display_type === 'individual') {
  footerText = dateLabel;
} else {
  footerText = piece_author && dateLabel
    ? `BY ${piece_author.toUpperCase()} / ${dateLabel}`
    : (piece_author ? `BY ${piece_author.toUpperCase()}` : dateLabel);
}

// Kraft-band excerpt: prefer the editorial bullets over the rubric prose.
// When bullets exist, join the first two with " · " — that surfaces the
// strongest editorial framing rather than the agent's own assessment.
let excerpt: string;
if (bullets && bullets.length >= 2) {
  excerpt = `${bullets[0]} · ${bullets[1]}`;
} else if (bullets && bullets.length === 1) {
  excerpt = bullets[0];
} else {
  const excerptRaw = rubric_rationale.split(/(?<=[.?!])\s+/)[0] ?? '';
  excerpt = excerptRaw.length > 140 ? excerptRaw.slice(0, 137) + '…' : excerptRaw;
}
if (excerpt.length > 160) excerpt = excerpt.slice(0, 157) + '…';

// Resolve the pull quote: prefer the editorial pull_quote, fall back to the
// agent-generated pull_quote_candidate, then to nothing. Parse ==phrase==
// markers into a span so the renderer can underline the highlight phrase.
type QuoteToken = { kind: 'plain'; text: string } | { kind: 'highlight'; text: string };
function tokenizePullQuote(s?: string | null): QuoteToken[] {
  if (!s) return [];
  const tokens: QuoteToken[] = [];
  const re = /==([^=]+)==/g;
  let last = 0;
  let m: RegExpExecArray | null;
  while ((m = re.exec(s)) !== null) {
    if (m.index > last) tokens.push({ kind: 'plain', text: s.slice(last, m.index) });
    tokens.push({ kind: 'highlight', text: m[1] });
    last = m.index + m[0].length;
  }
  if (last < s.length) tokens.push({ kind: 'plain', text: s.slice(last) });
  return tokens;
}
const quoteTokens = tokenizePullQuote(pull_quote ?? pull_quote_candidate);

// Per-tactic placeholder illustration. Hand-coded inline SVGs with subtle
// imperfections; Leonardo can override any of these by dropping a file at
// src/assets/tactic-illustrations/{tactic}.svg.
const TACTIC_ILLUSTRATIONS: Record<string, string> = {
  // Magnifying glass: slightly wobbly circle + handle.
  research_and_validation: `<svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M16 5 Q24 4 26 13 Q28 22 18 25 Q9 26 6 17 Q5 8 16 5 Z" />
    <path d="M23 23 Q28 27 33 33" />
  </svg>`,
  // 3x3 grid of slightly imperfect squares.
  systems_and_primitives: `<svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M5 5 L13 5.4 L12.8 13 L5 13 Z" />
    <path d="M16 5 L24 5 L24 13.2 L16 13 Z" />
    <path d="M27 5 L35 5.2 L35 13 L27 13 Z" />
    <path d="M5 16 L13 16 L13 24 L5 24 Z" />
    <path d="M16 16 L24 16 L24 24 L16 24 Z" />
    <path d="M27 16 L35 16 L35 24.2 L27 24 Z" />
    <path d="M5 27 L13 27 L13 35 L5 35 Z" />
    <path d="M16 27 L24 27.2 L24 35 L16 35 Z" />
    <path d="M27 27 L35 27 L35 35 L27 35 Z" />
  </svg>`,
  // Lightning bolt with a slight tilt.
  prototyping_and_exploration: `<svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M23 4 L11 21 L19 22 L15 36 L29 17 L21 16 Z" />
  </svg>`,
  // Branching arrow: a Y with arrowheads.
  critique_and_decision_making: `<svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M20 5 L20 19" />
    <path d="M20 19 L9 32" />
    <path d="M20 19 L31 32" />
    <path d="M9 32 L9 27 M9 32 L13 32" />
    <path d="M31 32 L31 27 M31 32 L27 32" />
  </svg>`,
  // 5-pointed star, slightly off the perfect geometry.
  craft_and_detail: `<svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M20 4 L24 15 L36 16 L26.5 24 L30 36 L20 29 L10 36 L13.5 24 L4 16 L16 15 Z" />
  </svg>`,
  // 4 nodes connected in a diamond.
  cross_functional_and_process: `<svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="20" cy="6" r="3" />
    <circle cx="6" cy="20" r="3" />
    <circle cx="34" cy="20" r="3" />
    <circle cx="20" cy="34" r="3" />
    <path d="M20 9 L8 18" />
    <path d="M22 9 L32 18" />
    <path d="M8 22 L18 32" />
    <path d="M32 22 L22 32" />
  </svg>`,
  // Speech bubble with a tail at the bottom-left.
  storytelling_and_narrative: `<svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M7 8 Q5 8 5 12 L5 24 Q5 28 9 28 L14 28 L11 35 L19 28 L31 28 Q35 28 35 24 L35 12 Q35 8 31 8 Z" />
  </svg>`,
  // Three head-shaped circles with shoulder lines.
  hiring_and_team: `<svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="10" cy="14" r="4" />
    <circle cx="20" cy="11" r="4" />
    <circle cx="30" cy="14" r="4" />
    <path d="M3 32 Q4 24 10 22 Q14 22 17 26" />
    <path d="M13 33 Q14 24 20 21 Q26 24 27 33" />
    <path d="M23 26 Q26 22 30 22 Q36 24 37 32" />
  </svg>`,
};
const tacticIllustration = tacticOverride
  ?? TACTIC_ILLUSTRATIONS[primaryTactic]
  ?? TACTIC_ILLUSTRATIONS.craft_and_detail;

const cardStyle = `--cover-color: ${coverColor}; --quiet-color: ${quietColor}; --wear-color: ${wearColor};`;
---

<article
  class="do-fn-card"
  style={cardStyle}
  role="button"
  tabindex="0"
  aria-expanded="false"
  aria-label={`${piece_title}, from ${source}. Activate to view editorial notes.`}
  data-slug={slug}
>
  <span class="do-fn-card-spine-indent do-fn-card-spine-indent-top"    aria-hidden="true"></span>
  <span class="do-fn-card-spine-indent do-fn-card-spine-indent-bottom" aria-hidden="true"></span>

  <div class="do-fn-card-cover">
    <span class="do-fn-card-wear" aria-hidden="true" set:html={wearSvg} />
    {logoSvg
      ? <span class="do-fn-card-logo" set:html={logoSvg} />
      : <span class="do-fn-card-wordmark">{wordmarkText}</span>}
  </div>

  <header class="do-fn-card-band">
    <div class="do-fn-card-band-top">
      <span>LDLR DESIGN</span>
      <span>FIELD NOTES</span>
    </div>
    <div class="do-fn-card-band-rule" aria-hidden="true"></div>
    <h3 class="do-fn-card-title">{piece_title}</h3>
    {excerpt && <p class="do-fn-card-excerpt">{excerpt}</p>}
  </header>

  <div class="do-fn-card-footer">
    <span class="do-fn-card-footer-text">{footerText}</span>
  </div>

  {/*
    Page clip: absolute inset:0, overflow:hidden. Exists so the page can sit
    at translateY(100%) in default state without leaking past the card box.
    The card itself stays overflow:visible.
  */}
  <div class="do-fn-card-page-clip" aria-hidden="true">
    <div
      class="do-fn-card-page"
      role="region"
      aria-label={`${piece_title} details. Press Escape to close.`}
    >
      <button
        type="button"
        class="do-fn-card-close"
        aria-label="Close"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round"
             aria-hidden="true">
          {/* Slight Q-curve waver gives the X a hand-drawn feel. */}
          <path d="M5.5 5 Q8 8.5 12 12 Q15.5 15 18.5 19" />
          <path d="M19 5 Q15.5 8 12 12 Q8.5 15 5 19" />
        </svg>
      </button>

      {quoteTokens.length > 0 && (
        <p class="do-fn-card-page-quote">
          {quoteTokens.map(t => (
            t.kind === 'highlight'
              ? <span class="do-fn-card-page-highlight">{t.text}</span>
              : <span>{t.text}</span>
          ))}
        </p>
      )}

      {bullets && bullets.length > 0 && (
        <>
          <div class="do-fn-card-page-bullets-header">Why it matters</div>
          <div class="do-fn-card-page-bullets">
            {bullets.map(b => (
              <div class="do-fn-card-page-bullet">— {b}</div>
            ))}
          </div>
        </>
      )}

      <a
        class="do-fn-card-page-cta"
        href={source_url}
        target="_blank"
        rel="noopener noreferrer"
      >
        Read on {source} →
      </a>

      <span
        class="do-fn-card-page-illustration"
        aria-hidden="true"
        set:html={tacticIllustration}
      />
    </div>
  </div>
</article>

<script>
  /**
   * Field Notes card flip controller.
   * Hoisted by Astro: runs once per page, operates over every .do-fn-card.
   */
  if (!(window as any).__fnCardController) {
    (window as any).__fnCardController = true;

    const cards = Array.from(document.querySelectorAll<HTMLElement>('.do-fn-card'));
    let flipped: HTMLElement | null = null;

    function openCard(card: HTMLElement): void {
      if (flipped && flipped !== card) closeCard(flipped, /*returnFocus*/ false);
      card.classList.add('is-flipped');
      card.setAttribute('aria-expanded', 'true');
      const page = card.querySelector<HTMLElement>('.do-fn-card-page-clip');
      if (page) page.setAttribute('aria-hidden', 'false');
      flipped = card;
      const close = card.querySelector<HTMLButtonElement>('.do-fn-card-close');
      window.setTimeout(() => close?.focus(), 380);
    }

    function closeCard(card: HTMLElement, returnFocus = true): void {
      card.classList.remove('is-flipped');
      card.setAttribute('aria-expanded', 'false');
      const page = card.querySelector<HTMLElement>('.do-fn-card-page-clip');
      if (page) page.setAttribute('aria-hidden', 'true');
      if (flipped === card) flipped = null;
      if (returnFocus) card.focus();
    }

    cards.forEach(card => {
      card.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (target.closest('.do-fn-card-close')) {
          e.preventDefault();
          closeCard(card);
          return;
        }
        if (target.closest('.do-fn-card-page-cta')) return;
        if (card.classList.contains('is-flipped')) return;
        openCard(card);
      });

      card.addEventListener('keydown', (e) => {
        if (e.target !== card) return;
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          if (card.classList.contains('is-flipped')) closeCard(card);
          else openCard(card);
        }
      });
    });

    document.addEventListener('click', (e) => {
      if (!flipped) return;
      if (!flipped.contains(e.target as Node)) closeCard(flipped);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && flipped) closeCard(flipped);
    });
  }
</script>
