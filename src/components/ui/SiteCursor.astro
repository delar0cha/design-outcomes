---
/**
 * SiteCursor — custom cursor for editorial pages (homepage, post detail).
 *
 * Drop this component anywhere inside a route that should opt in. The route's
 * top-level <main> (or any ancestor) must include the `do-cursor-host` class
 * so the native cursor is hidden across that subtree. The pill displays:
 *
 *     [logo]  ISSUE NN
 *
 * On hover over a clickable element the pill cross-fades to a 12px dot.
 * Skipped on coarse pointers and when reduced motion is preferred — the
 * native cursor is restored in those cases via CSS.
 */
interface Props {
  issue?: number;
}

const { issue } = Astro.props;
const issueLabel = issue ? `Issue ${String(issue).padStart(2, '0')}` : null;
