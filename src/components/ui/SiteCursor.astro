<script>
  // Custom cursor controller. Tracks the pointer, switches between pill and
  // dot states based on whether the target is interactive. One-time setup —
  // safe to mount once per page even if the component appears multiple times
  // (only the first instance binds; extras are removed).
  (() => {
    const cursors = document.querySelectorAll<HTMLElement>('[data-do-cursor]');
    if (!cursors.length) return;
    const cursor = cursors[0];
    cursors.forEach((el, i) => { if (i > 0) el.remove(); });

    const coarse = window.matchMedia('(pointer: coarse)').matches;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (coarse || reduce) {
      cursor.remove();
      return;
    }

    const onMove = (e: MouseEvent) => {
      cursor.style.transform = `translate3d(${e.clientX}px, ${e.clientY}px, 0)`;
      const t = e.target as Element | null;
      const interactive = !!t && !!t.closest(
        'a, button, [role="button"], input, select, textarea, label, summary, [data-clickable]'
      );
      cursor.classList.toggle('is-hover', interactive);
    };

    const onLeave = () => { cursor.style.opacity = '0'; };
    const onEnter = () => { cursor.style.opacity = '1'; };

    document.addEventListener('mousemove', onMove, { passive: true });
    document.addEventListener('mouseleave', onLeave);
    document.addEventListener('mouseenter', onEnter);
  })();
</script>
