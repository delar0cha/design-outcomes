---
import SiteLogo from './SiteLogo.astro';
import FooterSubscribeForm from '@components/islands/FooterSubscribeForm';
---

<footer class="do-footer">
  <div class="do-footer-grid">
    <!-- About column -->
    <div class="do-footer-about">
      <SiteLogo width={44} height={50} class="do-footer-logo-mark" />
      <p>
        Design Outcomes is the working notebook of a designer in practice, published in real time. Articles are full-length pieces on the decisions, tradeoffs, and lessons of design leadership as they happen. Field Notes are shorter takes on the tactics other teams are getting right, with annotations on what to take away. No sponsors. No popovers. Just the work.
      </p>
    </div>

    <!-- Subscribe column -->
    <div class="do-footer-sub">
      <div class="do-footer-label">The weekly digest</div>
      <FooterSubscribeForm client:load />
      <p class="do-footer-note">
        One email, Sunday. One link you will actually open. Unsubscribe with one click.
      </p>
    </div>

    <!-- Links column -->
    <div class="do-footer-links">
      <div class="do-footer-label">Elsewhere</div>
      <ul>
        <li>
          <a href="https://delarocha.myportfolio.com" target="_blank" rel="noopener">
            delarocha.myportfolio.com →
          </a>
        </li>
        <li>
          <a href="https://linkedin.com/in/delarocha" target="_blank" rel="noopener">
            linkedin.com/in/delarocha →
          </a>
        </li>
        <li>
          <a href="https://instagram.com/delar0cha" target="_blank" rel="noopener">
            instagram.com/delar0cha →
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="do-footer-rule"></div>

  <div class="do-footer-base">
    <span class="do-issue-label">ldlr.design · Set in Newsreader &amp; Instrument Sans.</span>
    <span class="do-issue-label">© 2026 Leonardo De La Rocha</span>
  </div>
</footer>
