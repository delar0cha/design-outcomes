---
import { LOGO_PATHS, LOGO_VIEW_BOX, LOGO_DEFAULT_FILL } from '@lib/logo';

interface Props {
  width?: number;
  height?: number;
  fill?: string;
  class?: string;
}

const {
  width  = 34,
  height = 38,
  fill   = LOGO_DEFAULT_FILL,
  class: className = '',
} = Astro.props;
---

<svg
  width={width}
  height={height}
  viewBox={LOGO_VIEW_BOX}
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  aria-hidden="true"
>
  <g fill={fill}>
    {LOGO_PATHS.map(d => <path d={d} />)}
  </g>
</svg>
