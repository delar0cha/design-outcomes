---
import '@styles/global.css';
import '@styles/terminal.css';
// import ThemeToggle from '@components/ui/ThemeToggle.astro';
//
// Terminal mode is wired end-to-end (tokens, CRT layers, ASCII pipeline,
// homepage frames, article tabular header, floppy-disk field notes) but
// the user-facing toggle is intentionally disabled until the field-notes
// dark-mode rendering is fully polished. To re-enable: uncomment this
// import + the <ThemeToggle /> mount at the bottom of <body>, restore
// the FOUC localStorage read below, and ship.

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogUrl?: string;
  ogType?: 'website' | 'article';
}

const {
  title       = 'Design Outcomes — Leonardo De La Rocha',
  description = 'Weekly design leadership writing by Leonardo De La Rocha, VP Product Design.',
  ogImage     = 'https://ldlr.design/images/work-header.png',
  ogUrl       = 'https://ldlr.design/',
  ogType      = 'website',
} = Astro.props;

const fullTitle = title.includes('Design Outcomes')
  ? title
  : `${title} — Design Outcomes`;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{fullTitle}</title>

  <!--
    Theme attribute setter. Terminal mode is currently disabled (see
    Base.astro frontmatter) — this script forces print mode on every
    load, ignoring any 'terminal' value previously persisted in
    localStorage during testing. Restore the localStorage read when
    re-enabling the toggle.
  -->
  <script is:inline>
    document.documentElement.setAttribute('data-theme', 'print');
  </script>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Alfa+Slab+One&family=Montserrat:wght@400;500;600;700&family=Instrument+Serif:ital@0;1&family=Instrument+Sans:ital,wght@0,400;0,500;1,400;1,500&family=IBM+Plex+Mono:wght@400;500&display=swap"
  />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;500;600&display=swap"
  />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/design-outcomes.svg" />

  <!-- SEO -->
  <meta name="description" content={description} />

  <!-- Open Graph -->
  <meta property="og:site_name" content="Design Outcomes — Leonardo De La Rocha" />
  <meta property="og:type"        content={ogType} />
  <meta property="og:title"       content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImage} />
  <meta property="og:url"         content={ogUrl} />

  <!-- Twitter / X card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImage} />
</head>
<body>
  <slot />

  {/*
    CRT flicker overlay (terminal-mode-only via CSS) and theme toggle
    are disabled while terminal mode is held back for further polish.
    Both are no-ops in print mode — the flicker layer's display rule
    is `display: none` outside [data-theme="terminal"] and the toggle
    has no callers without the import — but commenting them out keeps
    the rendered DOM clean.

    <div class="crt-flicker" aria-hidden="true"></div>
    <ThemeToggle />
  */}
</body>
</html>
