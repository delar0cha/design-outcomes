---
/**
 * audio-demo-snap.astro — preview of the audio player using the SNAP sticky
 * transition (instant show/hide instead of the production smooth fade+slide).
 *
 * Local-only comparison page for reviewing sticky behavior. Not linked from
 * the site nav. Visit /audio-demo-snap directly in dev.
 *
 * Uses the already-generated audio from structure-is-the-problem as the MP3
 * source so no extra credits are spent.
 */

import Base        from '@layouts/Base.astro';
import SiteNav     from '@components/islands/SiteNav';
import ShareRow    from '@components/islands/ShareRow';
import AudioPlayer from '@components/islands/AudioPlayer';

const demoAudio = 'https://310q2girql1gboba.public.blob.vercel-storage.com/audio/posts/structure-is-the-problem.mp3';
---

<Base title="Audio Player — Snap Sticky Demo" description="Local preview of the snap sticky transition." ogType="website">
  <main class="do-page do-post-page">
    <SiteNav client:load currentPath="/audio-demo-snap" />

    <article class="do-post">
      <div class="do-post-meta">
        <span>Demo</span>
        <span class="do-post-sep">·</span>
        <span>Snap sticky variant</span>
      </div>

      <h1 class="do-post-title">Audio Player — Snap Sticky Demo</h1>

      <p class="do-post-why">
        <span class="do-post-why-label">What you're looking at — </span>
        Same player component as an article page, but with <code>stickyMode="snap"</code>.
        Click <strong>Listen now</strong>, then scroll down past the player bar. In snap mode the
        sticky mini-player appears and disappears instantly with no transition. Compare against the
        production smooth variant on any real article page.
      </p>

      <div class="do-post-byline is-no-avatar">
        {/* LR avatar hidden — mirrors the production article page. */}
        <div>
          <div class="do-post-byline-name">Leonardo De La Rocha</div>
          <div class="do-post-byline-sub">VP Product Design · Demo</div>
        </div>
        <div class="do-post-byline-right" id="do-listen-btn-slot"></div>
      </div>

      <AudioPlayer
        client:load
        audio={demoAudio}
        slug="_demo-snap"
        stickyMode="snap"
      />

      <ShareRow client:load title="Audio Player — Snap Sticky Demo" url="https://ldlr.design/audio-demo-snap" topBar={true} />

      <div class="do-post-body">
        <p>
          Scroll down to cross the sticky threshold. The mini-player should appear at the top of
          the viewport with no fade, no slide — just an instant swap. The point of the demo is to
          A/B the motion feel against the production player, which uses a 180–220ms fade + micro
          slide.
        </p>
        <div style="height: 1400px; display: grid; place-items: center; color: var(--muted); font-family: var(--mono); font-size: 12px;">
          (scroll area — keep going)
        </div>
        <p>Now scroll back up. In snap mode, the mini-player disappears the instant the inline player re-enters the viewport.</p>
        <div style="height: 400px;"></div>
      </div>
    </article>
  </main>
</Base>
