---
import Base from '@layouts/Base.astro';
import SiteNav from '@components/islands/SiteNav';
import CategoryTag from '@components/ui/CategoryTag.astro';
import ShareRow from '@components/islands/ShareRow';
import AudioPlayer from '@components/islands/AudioPlayer';
import Illustration from '@components/islands/Illustration';
import SiteFooter from '@components/ui/SiteFooter.astro';
import { getAllPosts, toPostSummary, calcReadingTime } from '@lib/posts';
import { CATEGORIES } from '@lib/categories';
import { fmtDate } from '@lib/utils';
import { render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map(post => ({
    params: { slug: post.id.replace(/\.mdx?$/, '') },
    props:  { post },
  }));
}

const { post }    = Astro.props;
const { Content } = await render(post);

const slug       = post.id.replace(/\.mdx?$/, '');
const cat        = CATEGORIES[post.data.category];
const summary    = toPostSummary(post);
const pageUrl    = `https://ldlr.design/post/${slug}`;
const readTime   = calcReadingTime(post.body ?? '');

// Related posts: same category first, then fill from others (max 3)
const allPosts   = await getAllPosts();
const others     = allPosts.filter(p => p.id !== post.id);
const sameCat    = others.filter(p => p.data.category === post.data.category);
const rest       = others.filter(p => p.data.category !== post.data.category);
const related    = [...sameCat, ...rest].slice(0, 3).map(toPostSummary);

const coverRecipe = post.data.coverImage
  ? { kind: 'photo' as const, src: post.data.coverImage }
  : { kind: 'bars' as const, palette: ['#E8E0D0', '#2F4858', '#15120E'] as [string,string,string], seed: 1 };
---

<Base
  title={post.data.title}
  description={post.data.description}
  ogImage={post.data.coverImage
    ? `https://ldlr.design${post.data.coverImage}`
    : 'https://ldlr.design/images/work-header.png'}
  ogUrl={pageUrl}
  ogType="article"
>
  <main class="do-page do-post-page">
    <SiteNav client:load currentPath={`/post/${slug}`} />

    <!-- Cinematic sticky hero — two phases cycle text content across a
         pinned visual stage. Outer .do-post-hero-track is --hero-track-
         height tall; inner .do-post-hero is position:sticky/100vh and
         stays pinned while the reader scrolls through the track. The
         listener below maps track progress (0..1) to: image zoom, overlay
         fade, and crossfade between the headline phase and the "Why
         this matters" phase. The Why block only lives here — it's been
         removed from the article body render path to avoid duplication. -->
    <section class="do-post-hero-track" data-post-hero-track>
      <div class="do-post-hero">
        <div class="do-post-hero-media" data-post-hero-media>
          {post.data.coverImage
            ? <img
                src={post.data.coverImage}
                alt=""
                class="do-post-hero-img"
                draggable={false}
              />
            : <Illustration client:load recipe={coverRecipe} className="do-post-hero-svg" />}
        </div>
        <div class="do-post-hero-overlay" data-post-hero-overlay></div>

        <div class="do-post-hero-phase do-post-hero-phase--headline" data-post-hero-headline>
          <h1 class="do-post-hero-title">{post.data.title}</h1>
        </div>

        {post.data.why && (
          <div class="do-post-hero-phase do-post-hero-phase--why" data-post-hero-why>
            <div class="do-post-hero-why">
              <p class="do-post-hero-why-eyebrow">Why this matters</p>
              <p class="do-post-hero-why-body">{post.data.why}</p>
            </div>
          </div>
        )}
      </div>
    </section>

    <script>
      // Sticky two-phase hero scrollytelling. One rAF-throttled scroll/
      // resize listener reads the outer track's position against the
      // viewport and maps that to a 0..1 progress, then drives:
      //   • media zoom       1 → --hero-zoom-end (eased, full range)
      //   • overlay opacity  --hero-overlay-opacity → 0 (holds, then fades
      //                      during the final phase)
      //   • headline phase   visible 0 → phase-1-end, exits up+fades
      //                      during phase-1-end → phase-2-end
      //   • why phase        enters from below during phase-1-end →
      //                      phase-2-end, exits up+fades during
      //                      phase-2-end → 1
      // Using the track's bounding rect (not viewport scrollY) keeps the
      // sequence consistent regardless of scroll speed. Skipped when the
      // user prefers reduced motion — the CSS fallback renders both
      // phases stacked with a reduced overlay.
      (() => {
        const track    = document.querySelector<HTMLElement>('[data-post-hero-track]');
        const media    = document.querySelector<HTMLElement>('[data-post-hero-media]');
        const overlay  = document.querySelector<HTMLElement>('[data-post-hero-overlay]');
        const headline = document.querySelector<HTMLElement>('[data-post-hero-headline]');
        const why      = document.querySelector<HTMLElement>('[data-post-hero-why]');
        if (!track || !media || !overlay || !headline) return;

        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)');
        if (reduce.matches) return;

        const clamp01 = (v: number) => Math.max(0, Math.min(1, v));
        const easeOut = (t: number) => 1 - Math.pow(1 - t, 3);

        // Read tunables fresh per update — CSS vars may cross breakpoint
        // overrides, so resizing past a threshold must pick up the new
        // values without a reload.
        const readVars = () => {
          const s = getComputedStyle(document.documentElement);
          return {
            zoomEnd:      parseFloat(s.getPropertyValue('--hero-zoom-end'))         || 1.5,
            overlayStart: parseFloat(s.getPropertyValue('--hero-overlay-opacity'))  || 0.8,
            phase1End:    parseFloat(s.getPropertyValue('--hero-phase-1-end'))      || 0.33,
            phase2End:    parseFloat(s.getPropertyValue('--hero-phase-2-end'))      || 0.66,
          };
        };

        let ticking = false;
        const update = () => {
          ticking = false;
          const rect = track.getBoundingClientRect();
          const vh   = window.innerHeight || 1;
          const scrollable = rect.height - vh;
          const progress = scrollable > 0 ? clamp01(-rect.top / scrollable) : 0;
          const { zoomEnd, overlayStart, phase1End, phase2End } = readVars();

          // Image zoom runs linearly across the full progress so the
          // "pushing deeper" feel stays continuous — easing here makes
          // the image leap to near-final scale before the Why phase is
          // even on stage, which reads as a snap rather than a push.
          media.style.transform = `scale(${(1 + (zoomEnd - 1) * progress).toFixed(4)})`;

          // Overlay holds through phase 2, then fades to 0 during phase 3.
          const overlayFade = clamp01((progress - phase2End) / (1 - phase2End));
          overlay.style.opacity = (overlayStart * (1 - overlayFade)).toFixed(4);

          // Headline: visible through phase 1, exits during phase 2.
          const headlineExit = clamp01((progress - phase1End) / (phase2End - phase1End));
          const headlineExitEased = easeOut(headlineExit);
          headline.style.opacity   = (1 - headlineExit).toFixed(4);
          headline.style.transform = `translate3d(0, ${(-headlineExitEased * vh * 0.4).toFixed(2)}px, 0)`;

          // Why: enters during phase 2, exits during phase 3.
          if (why) {
            const whyEnter = clamp01((progress - phase1End) / (phase2End - phase1End));
            const whyExit  = clamp01((progress - phase2End) / (1 - phase2End));
            const whyEnterEased = easeOut(whyEnter);
            const whyExitEased  = easeOut(whyExit);
            const whyY = (1 - whyEnterEased) * vh * 0.4 - whyExitEased * vh * 0.4;
            why.style.opacity   = (whyEnter * (1 - whyExit)).toFixed(4);
            why.style.transform = `translate3d(0, ${whyY.toFixed(2)}px, 0)`;
          }
        };

        const onScroll = () => {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(update);
        };

        window.addEventListener('scroll', onScroll, { passive: true });
        window.addEventListener('resize', onScroll, { passive: true });
        update();
      })();
    </script>

    <!-- Article -->
    <article class="do-post">
      <div class="do-post-meta">
        <CategoryTag catId={post.data.category} size="lg" />
        <span class="do-post-sep">·</span>
        <span>{readTime}</span>
      </div>

      <div class="do-post-byline is-no-avatar">
        {/*
          LR avatar intentionally hidden for now — restore this block (and
          remove the `is-no-avatar` modifier above) to bring the monogram back.
          <div class="do-post-byline-avatar" aria-hidden="true">LR</div>
        */}
        <div>
          <div class="do-post-byline-name">Leonardo De La Rocha</div>
          <div class="do-post-byline-sub">
            VP Product Design · Published {fmtDate(post.data.publishedAt)}
          </div>
        </div>
        {/*
          Portal target for the Listen button — AudioPlayer hydrates below
          and injects its button here when `audio` frontmatter is present.
        */}
        <div class="do-post-byline-right" id="do-listen-btn-slot"></div>
      </div>

      {post.data.audio && (
        <AudioPlayer
          client:load
          audio={post.data.audio}
          slug={slug}
        />
      )}

      <!-- Share (top) -->
      <ShareRow client:load title={post.data.title} url={pageUrl} topBar={true} />

      <!-- MDX body -->
      <div class="do-post-body">
        <Content />
      </div>

      <!-- Share (bottom) -->
      <ShareRow client:load title={post.data.title} url={pageUrl} />

      <!-- Filed under -->
      <div class="do-post-end">
        <div class="do-post-end-rule"></div>
        <div class="do-post-end-row">
          <span>Filed under</span>
          <CategoryTag catId={post.data.category} />
          <span class="do-post-end-sub">— {cat?.sub}</span>
        </div>
      </div>
    </article>

    <!-- Related posts -->
    {related.length > 0 && (
      <section class="do-related">
        <div class="do-related-head">
          <div class="do-eyebrow">Read next</div>
          <h2>Three more pieces, chosen for you.</h2>
        </div>
        <div class="do-related-grid">
          {related.map(p => {
            const relRecipe = p.coverImage
              ? { kind: 'photo' as const, src: p.coverImage }
              : { kind: 'bars' as const, palette: ['#E8E0D0','#2F4858','#15120E'] as [string,string,string], seed: 1 };
            return (
              <a key={p.slug} class="do-card" href={`/post/${p.slug}`}>
                <div class="do-card-thumb">
                  <Illustration client:load recipe={relRecipe} className="do-card-svg" />
                </div>
                <div class="do-card-body">
                  <div class="do-card-top">
                    <CategoryTag catId={p.category} />
                    <span class="do-card-date">{fmtDate(p.publishedAt)}</span>
                  </div>
                  <h3 class="do-card-title"><span>{p.title}</span></h3>
                  <p class="do-card-excerpt">{p.description}</p>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    )}

    <SiteFooter />
  </main>
</Base>
